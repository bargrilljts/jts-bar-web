---
import type { Event } from "@/data/events";

type Props = {
  event: Event;
};

const { event } = Astro.props;
---

<article class="poster-card event-card">
  <div>
    <p class="event-date">{event.dayLabel}</p>
    <h3>{event.title}</h3>
    <p>{event.shortDescription}</p>
  </div>
  <div class="event-meta">
    <span>{event.startTime}</span>
    <span>{event.priceLabel}</span>
  </div>
  <div class="btn-row">
    <a class="button paper" href={`/events/${event.slug}`}>More Info</a>
    {event.rsvpUrl && <a class="button" href={event.rsvpUrl}>RSVP</a>}
    {event.ticketUrl && <a class="button" href={event.ticketUrl}>Tickets</a>}
  </div>
</article>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 22px;
  }

  .event-date {
    margin: 0 0 12px;
    color: var(--amber);
    font-weight: 900;
    text-transform: uppercase;
  }

  .event-card h3 {
    margin: 0 0 12px;
    font-family: Impact, "Arial Black", sans-serif;
    font-size: 2.7rem;
    line-height: 0.9;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .event-card p {
    margin: 0;
    color: #e4ded6;
    font-weight: 700;
    line-height: 1.45;
  }

  .event-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .event-meta span {
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 8px 11px;
    background: rgba(0, 0, 0, 0.28);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }
</style>
