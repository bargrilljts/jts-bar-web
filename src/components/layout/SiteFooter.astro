---
import { site } from "@/data/site";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h2>{site.name}</h2>
      <p>{site.description}</p>
      <div class="footer-links">
        <a href={site.instagram}>Instagram</a>
        <a href={site.facebook}>Facebook</a>
        <a href={site.tiktok}>TikTok</a>
      </div>
    </div>
    <div>
      <h3>Find us</h3>
      <p>{site.address}</p>
      <p><a href={`tel:${site.phone.replaceAll("-", "")}`}>{site.phone}</a></p>
      <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
    </div>
    <div>
      <h3>Book something</h3>
      <p>Tables, party nights, local acts. Nothing too precious.</p>
      <div class="footer-links">
        <a href="/reserve">Save a Table</a>
        <a href="/parties">Bring the Crew</a>
        <a href="/play-at-jts">Play the Room</a>
      </div>
    </div>
  </div>
</footer>
