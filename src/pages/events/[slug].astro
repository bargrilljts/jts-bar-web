---
import SiteLayout from "@/layouts/SiteLayout.astro";
import EventCard from "@/components/events/EventCard.astro";
import ReservePanel from "@/components/shared/ReservePanel.astro";
import { bookingLinks } from "@/data/booking";
import { publishedEvents } from "@/data/events";

export function getStaticPaths() {
  return publishedEvents.map((event) => ({
    params: { slug: event.slug },
    props: { event }
  }));
}

const { event } = Astro.props;
const related = publishedEvents.filter((item) => item.slug !== event.slug).slice(0, 3);
---

<SiteLayout title={event.title} description={event.shortDescription}>
  <main>
    <section class="section">
      <div class="container event-detail">
        <article class="paper-card event-poster">
          <p class="eyebrow">JT's event</p>
          <h1>{event.title}</h1>
          <div class="datebox">{event.dayLabel} / {event.startTime}</div>
          <p>{event.shortDescription}</p>
        </article>
        <div class="event-copy">
          <p class="eyebrow">{event.type.replace("-", " ")}</p>
          <h2 class="title">Come early if you want a good seat.</h2>
          <p class="lead">{event.description}</p>
          <dl class="details">
            <div><dt>Date</dt><dd>{event.dayLabel}</dd></div>
            <div><dt>Time</dt><dd>{event.startTime}{event.endTime ? ` - ${event.endTime}` : ""}</dd></div>
            <div><dt>Cover</dt><dd>{event.priceLabel}</dd></div>
          </dl>
          <div class="btn-row">
            {event.rsvpUrl && <a class="button primary" href={event.rsvpUrl}>RSVP</a>}
            {event.ticketUrl && <a class="button primary" href={event.ticketUrl}>Buy Tickets</a>}
            {!event.rsvpUrl && !event.ticketUrl && <span class="no-ticket">No tickets needed. Just show up early.</span>}
            <a class="button paper" href={event.reservationUrl ?? bookingLinks.eventNight}>Save a Table for This Night</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section compact">
      <div class="container">
        <h2 class="title" style="margin-bottom: 24px">More nights.</h2>
        <div class="card-grid">
          {related.map((item) => <EventCard event={item} />)}
        </div>
      </div>
    </section>

    <ReservePanel />
  </main>
</SiteLayout>

<style>
  .event-detail {
    display: grid;
    grid-template-columns: minmax(280px, 0.82fr) minmax(0, 1.18fr);
    gap: 36px;
    align-items: center;
  }

  .event-poster {
    padding: 30px;
    transform: rotate(-1.5deg);
  }

  .event-poster .eyebrow {
    color: var(--red);
    text-shadow: none;
  }

  .event-poster h1 {
    margin: 0;
    color: #111;
    font-family: Impact, "Arial Black", sans-serif;
    font-size: clamp(3.6rem, 8vw, 6rem);
    line-height: 0.86;
    text-transform: uppercase;
  }

  .event-poster p {
    color: #3d2b1b;
    font-weight: 900;
    line-height: 1.45;
  }

  .datebox {
    margin: 22px 0;
    border: 4px solid #111;
    padding: 12px;
    color: #111;
    font-family: "Arial Black", Impact, sans-serif;
    text-transform: uppercase;
  }

  .details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin: 28px 0;
  }

  .details div {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 14px;
    background: rgba(0, 0, 0, 0.26);
  }

  .details dt {
    color: var(--neon-blue);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .details dd {
    margin: 6px 0 0;
    font-weight: 900;
  }

  .no-ticket {
    display: inline-flex;
    align-items: center;
    color: var(--paper);
    font-weight: 900;
  }

  @media (max-width: 820px) {
    .event-detail,
    .details {
      grid-template-columns: 1fr;
    }
  }
</style>
