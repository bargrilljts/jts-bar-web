---
import SiteLayout from "@/layouts/SiteLayout.astro";
import ReservePanel from "@/components/shared/ReservePanel.astro";
import { bookingTypes } from "@/data/booking";
---

<SiteLayout title="Reserve" description="Save a table at JT's Bar & Grill in Mill Woods.">
  <main>
    <section class="section">
      <div class="container">
        <p class="eyebrow">Reserve</p>
        <h1 class="display">Coming with<br /><span class="neon">a crew?</span></h1>
        <p class="lead">Grab a table before the room fills up.</p>
      </div>
    </section>

    <section class="section compact">
      <div class="container card-grid booking-types">
        {
          bookingTypes.map((type) => (
            <a class="poster-card booking-card" href={type.href}>
              <h2>{type.title}</h2>
              <p>{type.text}</p>
              <span>Book This</span>
            </a>
          ))
        }
      </div>
    </section>

    <ReservePanel />

    <section class="section compact">
      <div class="container dark-card fallback">
        <p class="eyebrow">No booking link yet</p>
        <h2 class="title">Call the bar.</h2>
        <p>Until Cal.com is wired up, booking requests fall back to email or phone.</p>
        <a class="button primary" href="tel:7804635560">780-463-5560</a>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .booking-card,
  .fallback {
    padding: 28px;
  }

  .booking-card {
    color: #fff;
    text-decoration: none;
  }

  .booking-types h2 {
    margin: 0 0 12px;
    font-family: Impact, "Arial Black", sans-serif;
    font-size: 3rem;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .booking-types p,
  .fallback p {
    color: #e4ded6;
    font-weight: 800;
    line-height: 1.45;
  }

  .booking-card span {
    display: inline-block;
    margin-top: 18px;
    color: var(--neon-blue);
    font-family: "Arial Black", Impact, sans-serif;
    font-size: 0.78rem;
    text-transform: uppercase;
  }
</style>
